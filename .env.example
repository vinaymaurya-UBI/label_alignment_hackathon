# AI provider (optional - only if using Claude/AI features)
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini (Free tier available)
# Get API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Database (optional - defaults to SQLite at data/drug_ra.db)
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname
# For SQLite (default): sqlite+aiosqlite:///./data/drug_ra.db
DATABASE_URL=sqlite+aiosqlite:///./data/drug_ra.db

# API server (optional)
API_HOST=0.0.0.0
API_PORT=8000

# CORS - allowed frontend origins, comma-separated (optional)
# Add your frontend URL here for production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug and logging (optional)
DEBUG=true
LOG_LEVEL=INFO

# Vector store and embeddings (optional - for semantic search)
VECTOR_STORE_PATH=data/vector_store
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
